# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Display name used in email subjects / headers. Shown to end users.
NEXT_PUBLIC_PRODUCT_NAME=Your App

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Convex
NEXT_PUBLIC_CONVEX_URL=https://...convex.cloud
CONVEX_DEPLOY_KEY=prod:...
# Shared secret between Next.js webhook routes and Convex public mutations.
# Gate for write mutations triggered from Clerk / Stripe webhooks. Set the same
# value in the Convex dashboard (Settings → Environment Variables) as well.
CONVEX_WEBHOOK_SECRET=
# Clerk JWT issuer domain, e.g. https://clerk.yourapp.com or https://<slug>.clerk.accounts.dev
# Required by convex/auth.config.ts. Run: npx convex env set CLERK_JWT_ISSUER_DOMAIN <url>
CLERK_JWT_ISSUER_DOMAIN=

# Resend
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
# Optional: separate address for in-app feedback submissions (falls back to FROM_EMAIL)
FEEDBACK_EMAIL=feedback@yourdomain.com

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Trigger.dev
TRIGGER_SECRET_KEY=
